        "#| echo: false\n",
        "#| output: false\n",
        "\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import io, zipfile, urllib.request\n",
        "import statsmodels.formula.api as smf\n",
        "import warnings\n",
        "warnings.filterwarnings('ignore')\n",
        "\n",
        "# ── Load data ──────────────────────────────────────────────────────────────────\n",
        "url = \"https://davidcard.berkeley.edu/data_sets/njmin.zip\"\n",
        "col_names = [\n",
        "    \"sheet\", \"chain\", \"co_owned\", \"state\",\n",
        "    \"southj\", \"centralj\", \"northj\", \"pa1\", \"pa2\", \"shore\",\n",
        "    \"ncalls\", \"empft\", \"emppt\", \"nmgrs\", \"wage_st\", \"inctime\",\n",
        "    \"firstinc\", \"bonus\", \"pctaff\", \"meals\", \"open\", \"hrsopen\",\n",
        "    \"psoda\", \"pfry\", \"pentree\", \"nregs\", \"nregs11\",\n",
        "    \"type2\", \"status2\", \"date2\", \"ncalls2\",\n",
        "    \"empft2\", \"emppt2\", \"nmgrs2\", \"wage_st2\", \"inctime2\",\n",
        "    \"firstinc2\", \"special2\", \"meals2\", \"open2r\", \"hrsopen2\",\n",
        "    \"psoda2\", \"pfry2\", \"pentree2\", \"nregs2\", \"nregs112\"\n",
        "]\n",
        "\n",
        "resp = urllib.request.urlopen(url)\n",
        "zf = zipfile.ZipFile(io.BytesIO(resp.read()))\n",
        "raw = zf.read(\"public.dat\").decode(\"latin-1\")\n",
        "\n",
        "df = pd.read_csv(\n",
        "    io.StringIO(raw),\n",
        "    delim_whitespace=True,\n",
        "    header=None,\n",
        "    names=col_names,\n",
        "    na_values=\".\"\n",
        ")\n",
        "\n",
        "# ── Construct variables ────────────────────────────────────────────────────────\n",
        "df[\"fte1\"] = df[\"empft\"]  + 0.5 * df[\"emppt\"]  + df[\"nmgrs\"]\n",
        "df[\"fte2\"] = df[\"empft2\"] + 0.5 * df[\"emppt2\"] + df[\"nmgrs2\"]\n",
        "df[\"nj\"]   = (df[\"state\"] == 1).astype(int)\n",
        "\n",
        "for c in [1, 2, 3, 4]:\n",
        "    df[f\"chain_{c}\"] = (df[\"chain\"] == c).astype(int)\n",
        "\n",
        "df[\"co_owned\"] = df[\"co_owned\"].fillna(0)\n",
        "df_bal = df.dropna(subset=[\"fte1\", \"fte2\"]).copy()\n",
        "\n",
        "# ── Table 2 variables ──────────────────────────────────────────────────────────\n",
        "df_bal[\"pctft1\"]  = df_bal[\"empft\"] / (df_bal[\"empft\"] + df_bal[\"emppt\"].replace(0, np.nan))\n",
        "df_bal[\"wage425\"] = (df_bal[\"wage_st\"] == 4.25).astype(float)\n",
        "\n",
        "def ms(series):\n",
        "    s = series.dropna()\n",
        "    return f\"{s.mean():.3f} ({s.sem():.3f})\"\n",
        "\n",
        "pa = df_bal[df_bal[\"nj\"] == 0]\n",
        "nj = df_bal[df_bal[\"nj\"] == 1]\n",
        "\n",
        "t2_fte_pa   = ms(pa[\"fte1\"]);      t2_fte_nj   = ms(nj[\"fte1\"])\n",
        "t2_pctft_pa = ms(pa[\"pctft1\"]);   t2_pctft_nj = ms(nj[\"pctft1\"])\n",
        "t2_wage_pa  = ms(pa[\"wage_st\"]);  t2_wage_nj  = ms(nj[\"wage_st\"])\n",
        "t2_w425_pa  = ms(pa[\"wage425\"]);  t2_w425_nj  = ms(nj[\"wage425\"])\n",
        "t2_soda_pa  = ms(pa[\"psoda\"]);    t2_soda_nj  = ms(nj[\"psoda\"])\n",
        "t2_fry_pa   = ms(pa[\"pfry\"]);     t2_fry_nj   = ms(nj[\"pfry\"])\n",
        "t2_hrs_pa   = ms(pa[\"hrsopen\"]); t2_hrs_nj   = ms(nj[\"hrsopen\"])\n",
        "t2_own_pa   = ms(pa[\"co_owned\"]); t2_own_nj  = ms(nj[\"co_owned\"])\n",
        "\n",
        "n_pa = int((df_bal[\"nj\"] == 0).sum())\n",
        "n_nj = int((df_bal[\"nj\"] == 1).sum())\n",
        "\n",
        "# ── Table 3 values ─────────────────────────────────────────────────────────────\n",
        "def mean_se(series):\n",
        "    s = series.dropna()\n",
        "    return s.mean(), s.sem()\n",
        "\n",
        "pa1_m, pa1_se = mean_se(pa[\"fte1\"])\n",
        "pa2_m, pa2_se = mean_se(pa[\"fte2\"])\n",
        "nj1_m, nj1_se = mean_se(nj[\"fte1\"])\n",
        "nj2_m, nj2_se = mean_se(nj[\"fte2\"])\n",
        "\n",
        "pa_chg    = pa2_m - pa1_m\n",
        "nj_chg    = nj2_m - nj1_m\n",
        "pa_chg_se = (pa[\"fte2\"] - pa[\"fte1\"]).dropna().sem()\n",
        "nj_chg_se = (nj[\"fte2\"] - nj[\"fte1\"]).dropna().sem()\n",
        "\n",
        "nj_diff = (nj[\"fte2\"] - nj[\"fte1\"]).dropna()\n",
        "pa_diff = (pa[\"fte2\"] - pa[\"fte1\"]).dropna()\n",
        "did     = nj_chg - pa_chg\n",
        "did_se  = np.sqrt(nj_diff.var()/len(nj_diff) + pa_diff.var()/len(pa_diff))\n",
        "\n",
        "def f2(x): return f\"{x:.2f}\"\n",
        "def fse2(x): return f\"({x:.2f})\"\n",
        "\n",
        "# ── Table 4 regression ─────────────────────────────────────────────────────────\n",
        "df_reg = df_bal.copy()\n",
        "df_reg[\"delta_fte\"] = df_reg[\"fte2\"] - df_reg[\"fte1\"]\n",
        "\n",
        "m1 = smf.ols(\"delta_fte ~ nj\", data=df_reg.dropna(subset=[\"delta_fte\"])).fit()\n",
        "m2 = smf.ols(\n",
        "    \"delta_fte ~ nj + chain_2 + chain_3 + chain_4 + co_owned\",\n",
        "    data=df_reg.dropna(subset=[\"delta_fte\"])\n",
        ").fit()\n",
        "\n",
        "def rc(model, var):\n",
        "    return f\"{model.params[var]:.3f} ({model.bse[var]:.3f})\""
