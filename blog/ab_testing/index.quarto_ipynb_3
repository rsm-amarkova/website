        ")\n",
        "z_stat = theta_hat / se\n",
        "\n",
        "from scipy.stats import norm\n",
        "p_value = 2 * (1 - norm.cdf(abs(z_stat)))\n",
        "\n",
        "print(f\"z-statistic: {z_stat:.3f}\")\n",
        "print(f\"p-value:     {p_value:.4f}\")"
